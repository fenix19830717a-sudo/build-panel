{
  "node": {
    "name": "Node-Agent-1",
    "region": "default",
    "type": "worker",
    "port": 3100
  },
  "master": {
    "url": "http://localhost:3000",
    "heartbeatInterval": 30000,
    "reconnectDelay": 5000,
    "maxReconnectAttempts": 10
  },
  "security": {
    "secretKey": "your-secret-key-change-in-production",
    "tokenExpiry": 3600
  },
  "apps": {
    "directory": "./apps",
    "autoLoad": true,
    "hotReload": true
  },
  "monitoring": {
    "enabled": true,
    "interval": 10000,
    "metrics": ["cpu", "memory", "disk", "network"]
  },
  "logging": {
    "level": "info",
    "file": "logs/agent.log",
    "maxSize": 10485760,
    "maxFiles": 5
  }
}
