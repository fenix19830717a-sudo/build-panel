# BuildAI Framework - WebsiteTemplate
# Backend 环境变量示例

# 应用配置
NODE_ENV=production
PORT=3000

# 数据库配置
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=buildai
DB_PASSWORD=your_secure_password
DB_DATABASE=website_template

# JWT 配置
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Redis 配置（如使用）
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# 文件上传配置
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
