{
  "name": "dbbackup",
  "version": "1.0.0",
  "private": true,
  "description": "DBBackup - Database Backup Management Platform",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run start:dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "start": "cd backend && npm run start:prod",
    "docker:up": "docker-compose -f docker/docker-compose.yml up -d",
    "docker:up:full": "docker-compose -f docker/docker-compose.full.yml up -d",
    "docker:down": "docker-compose -f docker/docker-compose.yml down",
    "docker:down:full": "docker-compose -f docker/docker-compose.full.yml down",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "cd backend && npm run lint",
    "lint:frontend": "cd frontend && npm run lint"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "workspaces": [
    "backend",
    "frontend"
  ]
}
